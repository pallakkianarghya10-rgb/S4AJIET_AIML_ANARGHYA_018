public class MinArray {
    public static void main(String[] args) {
        int[] arr = {10, 5, 20, 8, 25, 3};
        int Min = arr[0];
        for (int i = 1; i < arr.length; i++) {
            if (arr[i] < Min) {
                Min = arr[i];
            }}
        System.out.println("Minimum element: " + Min);
    }}
